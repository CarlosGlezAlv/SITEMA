<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/admin_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar_admin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_admin"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/tec_red"
            app:title="@string/admin_titulo"
            app:titleTextColor="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ALUMNOS -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/admin_alumnos"
                        android:textColor="@color/tec_red"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="14dp"
                        android:background="@color/tec_red_light" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="2"
                        android:useDefaultMargins="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_alta_alumno"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/admin_btn_alta"
                            android:textColor="@color/tec_red"
                            app:strokeColor="@color/tec_red" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_ver_alumno"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/admin_btn_ver"
                            android:textColor="@color/tec_red"
                            app:strokeColor="@color/tec_red" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_editar_alumno"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/admin_btn_editar"
                            android:textColor="@color/tec_red"
                            app:strokeColor="@color/tec_red" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_eliminar_alumno"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/admin_btn_eliminar"
                            android:textColor="@color/danger"
                            app:strokeColor="@color/danger" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_asignar_materia_alumno"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnSpan="2"
                            android:layout_columnWeight="1"
                            android:text="Asignar Materia"
                            android:textColor="@color/tec_red"
                            app:strokeColor="@color/tec_red" />

                    </GridLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- DOCENTES -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/admin_docentes"
                        android:textColor="@color/tec_red"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="14dp"
                        android:background="@color/tec_red_light" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="2"
                        android:useDefaultMargins="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_alta_docente"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/admin_btn_alta"
                            android:textColor="@color/tec_red"
                            app:strokeColor="@color/tec_red" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_ver_docente"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/admin_btn_ver"
                            android:textColor="@color/tec_red"
                            app:strokeColor="@color/tec_red" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_editar_docente"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/admin_btn_editar"
                            android:textColor="@color/tec_red"
                            app:strokeColor="@color/tec_red" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_eliminar_docente"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/admin_btn_eliminar"
                            android:textColor="@color/danger"
                            app:strokeColor="@color/danger" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_asignar_materia_docente"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnSpan="2"
                            android:layout_columnWeight="1"
                            android:text="Asignar Materia"
                            android:textColor="@color/tec_red"
                            app:strokeColor="@color/tec_red" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_asignar_alumno_docente"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnSpan="2"
                            android:layout_columnWeight="1"
                            android:text="Asignar Alumno"
                            android:textColor="@color/tec_red"
                            app:strokeColor="@color/tec_red" />

                    </GridLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- MATERIAS -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/admin_materias"
                        android:textColor="@color/tec_red"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="14dp"
                        android:background="@color/tec_red_light" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="2"
                        android:useDefaultMargins="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_alta_materia"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/admin_btn_alta"
                            android:textColor="@color/tec_red"
                            app:strokeColor="@color/tec_red" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_ver_materia"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/admin_btn_ver"
                            android:textColor="@color/tec_red"
                            app:strokeColor="@color/tec_red" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_editar_materia"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/admin_btn_editar"
                            android:textColor="@color/tec_red"
                            app:strokeColor="@color/tec_red" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_eliminar_materia"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/admin_btn_eliminar"
                            android:textColor="@color/danger"
                            app:strokeColor="@color/danger" />

                    </GridLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>

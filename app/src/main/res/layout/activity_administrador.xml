<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/admin_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar_admin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_admin"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/tec_red"
            app:title="@string/admin_titulo"
            app:titleTextColor="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- BANNER DE BIENVENIDA -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/tec_red">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Panel de Administrador"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gestión completa del sistema"
                        android:textColor="#CCFFFFFF"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══════════════════════════════════════ -->
            <!--           SECCIÓN: ALUMNOS             -->
            <!-- ═══════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Título -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/admin_alumnos"
                        android:textColor="@color/tec_red"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="14dp"
                        android:background="@color/tec_red_light" />

                    <!-- Botones CRUD fila 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_alta_alumno"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="@string/admin_btn_alta"
                            android:textSize="13sp"
                            android:backgroundTint="@color/tec_red" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_editar_alumno"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="@string/admin_btn_editar"
                            android:textSize="13sp"
                            android:textColor="@color/tec_red"
                            app:strokeColor="@color/tec_red" />

                    </LinearLayout>

                    <!-- Botones CRUD fila 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_eliminar_alumno"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="@string/admin_btn_eliminar"
                            android:textSize="13sp"
                            android:textColor="@color/danger"
                            app:strokeColor="@color/danger" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_asignar_materia_alumno"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="Asignar Materia"
                            android:textSize="13sp"
                            android:textColor="@color/tec_red"
                            app:strokeColor="@color/tec_red" />

                    </LinearLayout>

                    <!-- TABLA DE ALUMNOS REGISTRADOS -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="10dp"
                        android:background="@color/tec_red_light" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Alumnos registrados"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <!-- Encabezado tabla alumnos -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:orientation="horizontal"
                        android:background="@color/tec_red_light"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:paddingStart="10dp"
                            android:text="No. Control"
                            android:textColor="@color/tec_red"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:text="Nombre"
                            android:textColor="@color/tec_red"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.2"
                            android:paddingEnd="10dp"
                            android:text="Teléfono"
                            android:textAlignment="textEnd"
                            android:textColor="@color/tec_red"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Lista de alumnos -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_admin_alumnos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_admin_alumno" />

                    <TextView
                        android:id="@+id/tv_admin_sin_alumnos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="Sin alumnos registrados."
                        android:textAlignment="center"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="italic"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══════════════════════════════════════ -->
            <!--           SECCIÓN: DOCENTES            -->
            <!-- ═══════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Título -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/admin_docentes"
                        android:textColor="@color/tec_red"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="14dp"
                        android:background="@color/tec_red_light" />

                    <!-- Botones CRUD fila 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_alta_docente"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="@string/admin_btn_alta"
                            android:textSize="13sp"
                            android:backgroundTint="@color/tec_red" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_editar_docente"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="@string/admin_btn_editar"
                            android:textSize="13sp"
                            android:textColor="@color/tec_red"
                            app:strokeColor="@color/tec_red" />

                    </LinearLayout>

                    <!-- Botones CRUD fila 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_eliminar_docente"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="@string/admin_btn_eliminar"
                            android:textSize="13sp"
                            android:textColor="@color/danger"
                            app:strokeColor="@color/danger" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_asignar_materia_docente"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="Asignar Materia"
                            android:textSize="13sp"
                            android:textColor="@color/tec_red"
                            app:strokeColor="@color/tec_red" />

                    </LinearLayout>

                    <!-- Botón Asignar alumno (ancho completo) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_asignar_alumno_docente"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Asignar Alumno a Docente"
                        android:textSize="13sp"
                        android:textColor="@color/tec_red"
                        app:strokeColor="@color/tec_red" />

                    <!-- TABLA DE DOCENTES REGISTRADOS -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="10dp"
                        android:background="@color/tec_red_light" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Docentes registrados"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <!-- Encabezado tabla docentes -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:orientation="horizontal"
                        android:background="@color/tec_red_light"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:paddingStart="10dp"
                            android:text="No. Emp."
                            android:textColor="@color/tec_red"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:text="Nombre"
                            android:textColor="@color/tec_red"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.5"
                            android:paddingEnd="10dp"
                            android:text="Dirección"
                            android:textAlignment="textEnd"
                            android:textColor="@color/tec_red"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Lista de docentes -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_admin_docentes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_admin_docente" />

                    <TextView
                        android:id="@+id/tv_admin_sin_docentes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="Sin docentes registrados."
                        android:textAlignment="center"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="italic"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══════════════════════════════════════ -->
            <!--           SECCIÓN: MATERIAS            -->
            <!-- ═══════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Título -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/admin_materias"
                        android:textColor="@color/tec_red"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="14dp"
                        android:background="@color/tec_red_light" />

                    <!-- Botones CRUD fila 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_alta_materia"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="@string/admin_btn_alta"
                            android:textSize="13sp"
                            android:backgroundTint="@color/tec_red" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_editar_materia"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="@string/admin_btn_editar"
                            android:textSize="13sp"
                            android:textColor="@color/tec_red"
                            app:strokeColor="@color/tec_red" />

                    </LinearLayout>

                    <!-- Botones CRUD fila 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_eliminar_materia"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="@string/admin_btn_eliminar"
                            android:textSize="13sp"
                            android:textColor="@color/danger"
                            app:strokeColor="@color/danger" />

                        <!-- espacio vacío para mantener simetría -->
                        <Space
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp" />

                    </LinearLayout>

                    <!-- TABLA DE MATERIAS REGISTRADAS -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="10dp"
                        android:background="@color/tec_red_light" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Materias registradas"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <!-- Encabezado tabla materias -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:orientation="horizontal"
                        android:background="@color/tec_red_light"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:paddingStart="10dp"
                            android:text="Clave"
                            android:textColor="@color/tec_red"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2.5"
                            android:text="Nombre"
                            android:textColor="@color/tec_red"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.8"
                            android:paddingEnd="10dp"
                            android:text="Créd."
                            android:textAlignment="textEnd"
                            android:textColor="@color/tec_red"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Lista de materias -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_admin_materias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_admin_materia" />

                    <TextView
                        android:id="@+id/tv_admin_sin_materias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="Sin materias registradas."
                        android:textAlignment="center"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="italic"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
